# ==============================================================
# SECURE AUTHENTICATION PLATFORM - DEVELOPMENT CONFIGURATIONS
# ==============================================================

# Server configuration
NODE_ENV=development
PORT=5000

# Database credentials (PostgreSQL Connection String)
# Example: postgresql://username:password@localhost:5432/db_name?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/secure_auth?schema=public"

# Cryptographical JSON Web Token Secret Keys
# Generate high-entropy 256-bit keys using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="e9fb2193b0cbfa3a31e8c18742880cf55de9c162810fbefb8d6092055cb595f9"
JWT_REFRESH_SECRET="cd8d26426466f28de3e4be9ccf11f42e588dbca67b36f78f8d2091fb5c5c5cb2"

# Security Cookie Secret Key
COOKIE_SECRET="d53de7091bfbc2d398ca8b18d227f2c69b626dcdbe2bc7ef28d6c7b949bc5efd"

# Authorized Client URL Context (For CORS and email redirections)
CLIENT_URL="http://localhost:3000"

# Production SMTP Mail Server configurations
# Optional in development; the server automatically falls back to secure local console log interception.
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER=""
SMTP_PASS=""
